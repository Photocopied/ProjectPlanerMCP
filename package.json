{
  "name": "project-planer-mcp",
  "version": "0.7.0",
  "description": "MCP server for rich project planning with features, techspecs, research, plans, and tasks",
  "type": "module",
  "bin": {
    "project-planer-mcp": "./build/index.js"
  },
  "files": [
    "build/"
  ],
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "prepare": "npm run build",
    "start": "node build/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "project-planning",
    "model-context-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.1",
    "env-paths": "^4.0.0"
  },
  "devDependencies": {
    "@types/env-paths": "^1.0.2",
    "@types/node": "^22.14.1",
    "@vitest/coverage-v8": "^4.1.7",
    "typescript": "^5.8.3",
    "vitest": "^4.1.7"
  }
}
